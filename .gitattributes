# Normalize line endings so Git status/diffs match what teammates see (Windows-friendly: editors handle LF fine).
* text=auto

# Source and data
*.cs text eol=lf diff=csharp
*.json text eol=lf
*.xml text eol=lf
*.txt text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.csv text eol=lf

# Unity YAML / text assets
*.meta text eol=lf
*.asset text eol=lf
*.prefab text eol=lf
*.unity text eol=lf
*.anim text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.mask text eol=lf
*.mat text eol=lf
*.physicMaterial text eol=lf
*.physicsMaterial text eol=lf
*.physicsMaterial2D text eol=lf
*.physicMaterial2D text eol=lf
*.shader text eol=lf
*.compute text eol=lf
*.cginc text eol=lf
*.hlsl text eol=lf
*.shadergraph text eol=lf
*.shadersubgraph text eol=lf
*.asmdef text eol=lf
*.asmref text eol=lf
*.rsp text eol=lf
*.uxml text eol=lf
*.uss text eol=lf
*.inputactions text eol=lf

# Project / tooling text
*.sln text eol=lf
*.csproj text eol=lf
*.props text eol=lf
*.targets text eol=lf
*.config text eol=lf
.editorconfig text eol=lf
.gitattributes text eol=lf
.gitignore text eol=lf

